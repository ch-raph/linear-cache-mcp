{
  "settings": {
    "toolPrefix": "none"
  },
  "mcpServers": {
    "linear-cache": {
      "command": "npx",
      "args": ["-y", "linear-cache-mcp"],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}",
        "LINEAR_TEAM_ID": "your-linear-team-id"
      },
      "directTools": true,
      "lifecycle": "lazy"
    }
  }
}

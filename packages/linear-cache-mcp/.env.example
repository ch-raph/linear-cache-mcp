# Copy to .env for local development.
# Never commit .env or real API keys.

# Required for live Linear sync/write-through tools.
LINEAR_API_KEY=lin_api_your_key_here

# Optional but recommended: restrict issue sync/create defaults to one Linear team.
LINEAR_TEAM_ID=your-linear-team-id

# Optional: defaults to <repo>/.agent/linear-cache when launched from a repo.
# LINEAR_CACHE_ROOT=/absolute/path/to/project/.agent/linear-cache
